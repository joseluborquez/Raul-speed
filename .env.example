# Yumbo Japan API Key
# Obtener en: https://yumbo-jp.com/user/user/profile.html
YUMBO_API_KEY=

# Banco Central de Chile — API de tipo de cambio.
# Registro gratuito: https://si3.bcentral.cl/estadisticas/Principal1/Web/BancoCentralAboutNosotros/registroUsuariosBCCH/index.php
BCENTRAL_USER=
BCENTRAL_PASS=
BCENTRAL_SERIES_JPY=F072.CLP.JPY.N.O.D

# Fórmula de negocio: precio_JPY x tipo_cambio_CLP x mult_1 x mult_2
FORMULA_MULTIPLICADOR_1=1.1
FORMULA_MULTIPLICADOR_2=2

# Supabase — tabla settings (costo de logística) + Auth del panel admin.
# La anon key es pública por diseño (segura de exponer en el cliente).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service role. Salta RLS por completo, úsala SOLO en el
# servidor (webhooks de pago, API de admin de pedidos). Se obtiene en
# Project Settings → API → service_role secret. NUNCA exponer al navegador.
SUPABASE_SERVICE_ROLE_KEY=

# Allowlist de correos con acceso al panel /admin. Separados por coma.
# Sin esto, cualquiera que logre autenticarse contra el proyecto de
# Supabase (si el signup está abierto) entraría al panel completo.
ADMIN_EMAILS=empresaraulspeed@gmail.com

# Mercado Pago — Checkout Pro. Access token de prueba o de producción.
# https://www.mercadopago.cl/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=

# Transbank Webpay Plus. En integration se puede usar el código de
# comercio y api key públicos de pruebas de Transbank (mismos para
# cualquier desarrollador); cambiar a las credenciales reales + "production"
# recién cuando el comercio esté aprobado por Transbank para producción.
WEBPAY_COMMERCE_CODE=597055555532
WEBPAY_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
WEBPAY_ENV=integration

# Flow.cl — apiKey/secretKey de tu cuenta (sandbox: crear cuenta separada
# en sandbox.flow.cl; producción: panel de flow.cl → API).
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_ENV=sandbox
